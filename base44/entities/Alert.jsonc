{
  "name": "Alert",
  "type": "object",
  "properties": {
    "type": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "critical"
      ]
    },
    "message": {
      "type": "string"
    },
    "entity_ref": {
      "type": "string"
    },
    "resolved": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "type",
    "severity",
    "message"
  ]
}